# WL OPS Backend — copy this to .env and fill in your values

# Server
PORT=8787
HOST=0.0.0.0

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wl_ops
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# JWT — generate a strong random string: openssl rand -hex 64
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRY=12h
JWT_REFRESH_EXPIRY=7d

# App
NODE_ENV=production
